# ============================================================
# 🤖 基金报告助手 - 用户配置文件
# ============================================================
# 📝 使用方法：
#   1. 将此文件复制为 config.yaml: cp config.yaml.example config.yaml
#   2. 修改下面的配置项（主要修改 "持仓配置" 部分）
#   3. 启动程序: python start.py
# ============================================================


# ============================================================
# 1️⃣ 【必填】用户持仓配置
# 填写你所持有的基金信息
# 格式说明：
#   - code:  基金代码（6位数字，必填）
#   - name:  基金名称（必填）
#   - cost:  你的总投入金额，单位：元（必填）
#   - shares: 你持有的份额（必填）
# ============================================================
portfolios:
  default_user:              # 用户标识（可改为你的名字）
    funds:
      # 示例：华夏成长混合
      - code: "000001"       # 基金代码
        name: "华夏成长混合"  # 基金名称
        cost: 10000          # 总投入：10000元
        shares: 5000         # 持有份额：5000份

      # 示例：易方达优质精选混合(QDII)
      - code: "110011"
        name: "易方达优质精选混合(QDII)"
        cost: 20000
        shares: 8000
      # 示例：招商中证白酒指数(LOF)A
      - code: "161725"
        name: "招商中证白酒指数(LOF)A)"
        cost: 15000
        shares: 6000

      # 📌 在此下方添加你实际持有的基金
      # 格式：
      # - code: "基金代码"
      #   name: "基金名称"
      #   cost: 投入总金额
      #   shares: 持有份额


# ============================================================
# 2️⃣ 【可选】微信配置
# 如需通过微信交互，请填写以下配置
# 不自用微信模式可跳过本部分
# ============================================================
wechat:
  # 是否启用微信模式
  # true  = 启动微信机器人（需安装 itchat）
  # false = 仅使用控制台模式
  enabled: false

  # ⚠️ 接收报告的微信联系人
  # 必填：至少有一个人名或 "文件传输助手"
  receivers:
    - "文件传输助手"          # 推荐使用文件传输助手
    # - "你的微信昵称"         # 替换为你的微信昵称或备注名

  # 自动回复：收到消息后是否自动回复
  auto_reply: true


# ============================================================
# 3️⃣ 【可选】报告配置
# 控制报告的输出格式和内容
# ============================================================
report:
  language: "zh"             # 报告语言：zh=中文
  show_recommendations: true # 是否在报告中显示基金推荐
  recommend_count: 5         # 推荐的基金数量（1-10）
  max_risk_warnings: 3       # 每支基金最多显示的风险提醒数


# ============================================================
# 4️⃣ 【可选】推荐算法参数
# 调整基金推荐评分模型的权重
# 权重总和 = 1.0，修改前请理解各参数含义
# ============================================================
algorithm:
  # 多因子评分权重配置
  # 数值越大，该指标对最终评分影响越大
  weights:
    # --- 收益因子（总权重 0.70 = 70%）---
    recent_1m: 0.08          # 近1月收益评分权重
    recent_3m: 0.12          # 近3月收益评分权重
    recent_6m: 0.15          # 近6月收益评分权重
    recent_1y: 0.20          # 近1年收益评分权重 ★ 最重要
    recent_3y: 0.15          # 近3年收益评分权重

    # --- 风险因子（总权重 0.15 = 15%）---
    max_drawdown_neg: 0.10   # 最大回撤评分权重（越小越好）
    volatility_neg: 0.05     # 波动率评分权重（越小越好）

    # --- 稳定因子（总权重 0.10 = 10%）---
    manager_stability: 0.05  # 基金经理稳定性评分权重
    fund_rating: 0.05        # 基金评级评分权重

    # --- 规模因子（总权重 0.05 = 5%）---
    size_score: 0.05         # 基金规模评分权重（20-100亿最优）

  # 排除基金规模超过此值的基金（单位：亿元）
  # 规模过大可能影响超额收益
  max_fund_size: 500


# ============================================================
# 5️⃣ 【可选】LLM 配置（使用 LangChain Agent 时必填）
# 配置 AI 模型接口，用于驱动猫娘基金助手
# ============================================================
llm:
  # API 密钥（从模型提供商获取）
  api_key: "your-api-key-here"
  
  # API 地址（兼容 OpenAI API 格式）
  # 通义千问：https://dashscope.aliyuncs.com/compatible-mode/v1
  # 零一万物：https://api.lingyiwanwu.com/v1
  # DeepSeek：https://api.deepseek.com
  # OpenAI：https://api.openai.com/v1
  api_base: "https://dashscope.aliyuncs.com/compatible-mode/v1"
  
  # 模型名称
  # 通义千问：qwen-plus, qwen-max, qwen-turbo
  # 零一万物：yi-lightning, yi-large
  # DeepSeek：deepseek-chat
  # OpenAI：gpt-4o, gpt-4o-mini
  model: "qwen-plus"
  
  # 生成温度（0.0-1.0），越高回答越随机
  # 猫娘模式建议 0.7-0.9，更有"人味"
  temperature: 0.8
  
  # Agent 调试模式（开启后会在控制台打印Agent思考过程）
  verbose: false


# ============================================================
# 6️⃣ 【必填】数据库配置（TiDB Serverless）
# 用于持久化存储基金数据（历史净值、收益率等）
# 连接字符串格式：mysql://user:password@host:port/database
# ============================================================
database:
  # 是否启用数据库
  enabled: true
  
  # TiDB 兼容 MySQL 协议
  type: tidb
  host: "gateway01.ap-southeast-1.prod.aws.tidbcloud.com"
  port: 4000
  user: "276VuVcShrzawZh.root"
  password: "Wx9nZ1e5pPk3rOgN"
  database: "test"
  
  # 连接池大小
  pool_size: 5

